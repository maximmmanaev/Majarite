# Majarite prod environment example
# Copy this file to /opt/majorite/env/prod/.env on server.
# Never commit real production env files.

MAJARITE_ENV=prod
MAJARITE_PROJECT_NAME=majarite
MAJARITE_DOMAIN=helpdesk.example.com
TZ=Europe/London

# External reverse proxy
NGINX_IMAGE=nginx:1.27.5-alpine
HTTP_PORT=80

# Zammad
ZAMMAD_IMAGE_REPO=ghcr.io/zammad/zammad
ZAMMAD_VERSION=7.0.1-0019
ZAMMAD_FQDN=helpdesk.example.com
ZAMMAD_HTTP_TYPE=https
ZAMMAD_NGINX_PORT=8080
ZAMMAD_ELASTICSEARCH_ENABLED=false

# Zammad internal dependencies
ZAMMAD_REDIS_IMAGE=redis:8.6.2-alpine
ZAMMAD_MEMCACHED_IMAGE=memcached:1.6.41-alpine

# PostgreSQL image
POSTGRES_IMAGE=postgres:17.9-alpine

# Majorite event store
MAJORITE_POSTGRES_DB=majorite
MAJORITE_POSTGRES_USER=majorite
MAJORITE_POSTGRES_PASSWORD=replace-in-real-server-env

# Zammad database
ZAMMAD_POSTGRES_DB=zammad_production
ZAMMAD_POSTGRES_USER=zammad
ZAMMAD_POSTGRES_PASSWORD=replace-in-real-server-env

# Valkey for Majorite temporary sessions, dedupe, retries
VALKEY_IMAGE=valkey/valkey:8.1.3-alpine

# Node-RED
NODE_RED_IMAGE=nodered/node-red:4.0.9
NODE_RED_CREDENTIAL_SECRET=replace-in-real-server-env

# Runtime paths
MAJARITE_DATA_DIR=/opt/majorite/data
MAJARITE_LOG_DIR=/opt/majorite/logs

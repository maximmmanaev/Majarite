# Majarite dev environment example
# Copy this file to .env or env/dev/.env locally.
# Never commit real .env files.

MAJARITE_ENV=dev
MAJARITE_PROJECT_NAME=majarite
MAJARITE_DOMAIN=localhost
TZ=Europe/London

# External reverse proxy
NGINX_IMAGE=nginx:1.27.5-alpine
HTTP_PORT=8080

# Zammad
ZAMMAD_IMAGE_REPO=ghcr.io/zammad/zammad
ZAMMAD_VERSION=7.0.1-0019
ZAMMAD_FQDN=localhost
ZAMMAD_HTTP_TYPE=http
ZAMMAD_NGINX_PORT=8080
ZAMMAD_ELASTICSEARCH_ENABLED=false

# Zammad internal dependencies
ZAMMAD_REDIS_IMAGE=redis:8.6.2-alpine
ZAMMAD_MEMCACHED_IMAGE=memcached:1.6.41-alpine

# PostgreSQL image
POSTGRES_IMAGE=postgres:17.9-alpine

# Majorite event store
MAJORITE_POSTGRES_DB=majorite
MAJORITE_POSTGRES_USER=majorite
MAJORITE_POSTGRES_PASSWORD=change-me-dev-majorite

# Zammad database
ZAMMAD_POSTGRES_DB=zammad_production
ZAMMAD_POSTGRES_USER=zammad
ZAMMAD_POSTGRES_PASSWORD=change-me-dev-zammad

# Valkey for Majorite temporary sessions, dedupe, retries
VALKEY_IMAGE=valkey/valkey:8.1.3-alpine

# Node-RED
NODE_RED_IMAGE=nodered/node-red:4.0.9
NODE_RED_CREDENTIAL_SECRET=change-me-dev-node-red-secret

# Runtime paths
MAJARITE_DATA_DIR=./data
MAJARITE_LOG_DIR=./logs

# Email intake adapter
EMAIL_ADAPTER_IMAGE=majarite/email-adapter:0.1.0
EMAIL_WEBHOOK_TOKEN=change-me-dev-email-webhook-token
MAJORITE_DATABASE_URL=postgresql://majorite:change-me-dev-majorite@majorite-postgres:5432/majorite

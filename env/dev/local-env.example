# Local development env override.
#
# Correct usage:
#   cp env/dev/.env.example env/dev/.env.local
#   cat env/dev/local-env.example >> env/dev/.env.local
#   nano env/dev/.env.local
#
# Never commit env/dev/.env.local.

# Zammad API bridge
ZAMMAD_API_BASE_URL=http://zammad-nginx:8080/api/v1
ZAMMAD_API_TOKEN=replace-with-local-zammad-api-token
ZAMMAD_DEFAULT_GROUP=Users
ZAMMAD_DEFAULT_CUSTOMER_EMAIL=majarite-local-customer@example.com

# Majarite environment example
# Copy this file to .env for local development.
# Never commit real .env files.

MAJARITE_ENV=dev
MAJARITE_DOMAIN=localhost

POSTGRES_DB=majarite
POSTGRES_USER=majarite
POSTGRES_PASSWORD=change_me

VALKEY_PASSWORD=change_me

NODE_RED_CREDENTIAL_SECRET=change_me

TELEGRAM_BOT_TOKEN=change_me
TELEGRAM_ADMIN_CHAT_ID=change_me

ZAMMAD_FQDN=http://localhost
ZAMMAD_RAILS_TRUSTED_PROXIES=127.0.0.1,::1
